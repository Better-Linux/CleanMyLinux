---
import { GITHUB_URL } from "../config";
---
<section class="relative z-10 max-w-7xl mx-auto px-6 pt-24 pb-20 text-center overflow-hidden">
  <div class="relative z-10 max-w-5xl mx-auto space-y-8">
    <div id="hero-tag" class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full bg-[#EA580C]/5 border border-[#EA580C]/15 text-[11px] font-bold tracking-wider uppercase text-[#FDBA74] opacity-0">
      <span class="w-1.5 h-1.5 rounded-full bg-[#EA580C] animate-pulse"></span>
      Safely Tune Up Your Linux
    </div>

    <h1 id="hero-title" class="text-5xl sm:text-7xl md:text-8xl font-extrabold tracking-tight text-white leading-[0.95] font-display uppercase opacity-0">
      It's time to<br/><span class="orange-gradient-text font-black">evolve</span> Linux.
    </h1>

    <p id="hero-desc" class="text-base sm:text-lg text-white/50 max-w-2xl mx-auto leading-relaxed font-medium opacity-0">
      Most Linux cleaners are risky and can break your system files. CleanMyLinux is different. Built with Rust, it lets you easily manage your apps, safely scan for leftover junk, and keep your desktop running fast - without breaking anything.
    </p>

    <div id="hero-ctas" class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-6 opacity-0">
      <a href={`${GITHUB_URL}/releases/latest`} target="_blank" rel="noopener noreferrer" class="btn-shine group w-full sm:w-auto px-8 py-4 rounded-2xl bg-linear-to-r from-[#EA580C] to-[#FDBA74] text-black font-black text-xs uppercase tracking-wider shadow-lg shadow-[#EA580C]/10 transition-all duration-300 hover:scale-[1.02] hover:brightness-110 active:scale-[0.98] flex items-center justify-center gap-2.5">
        <!-- Custom Download SVG -->
        <svg class="w-4 h-4 text-black stroke-current group-hover:translate-y-0.5 transition-transform duration-300" fill="none" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Download for Linux
      </a>
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="btn-cyber-glow group w-full sm:w-auto px-8 py-4 rounded-2xl morphism-panel border border-white/5 bg-white/1 text-white font-black text-xs uppercase tracking-wider transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] flex items-center justify-center gap-2.5">
        <!-- Custom SVG GitHub Icon -->
        <svg class="w-4 h-4 text-[#FDBA74] fill-current group-hover:rotate-6 transition-transform duration-300" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        View on GitHub
      </a>
    </div>
  </div>
</section>

<style>
  .btn-shine {
    position: relative;
    overflow: hidden;
  }
  .btn-shine::after {
    content: '';
    position: absolute;
    top: 0;
    left: -150%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      to right,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.4) 50%,
      rgba(255, 255, 255, 0) 100%
    );
    transform: skewX(-25deg);
    transition: left 0.75s ease;
  }
  .btn-shine:hover::after {
    left: 150%;
  }

  /* Cyber Glow Pulse for Secondary Button */
  .btn-cyber-glow {
    position: relative;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .btn-cyber-glow:hover {
    border-color: rgba(234, 88, 12, 0.6) !important;
    background: rgba(234, 88, 12, 0.04) !important;
    box-shadow: 
      0 0 30px rgba(234, 88, 12, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }
</style>
